# Copy this file to .env on the VPS next to docker-compose.yml, fill in real values,
# then run: docker compose up -d

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=af-system

# --- App ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me
# Public URL the app is served at (used by Auth.js for callbacks/redirects)
AUTH_URL=https://your-domain.example.com

# --- Ports exposed on the VPS host (optional, defaults shown) ---
APP_PORT=4700
POSTGRES_PORT=5438

# --- Image tag to deploy (optional, defaults shown) ---
IMAGE_TAG=1.0.0
